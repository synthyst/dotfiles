#!/bin/bash

################################################################################
# Termux File Editor
# A bash script that detects file types and provides intelligent handling:
# - Images, videos, audio: automatically saves to downloads
# - Text/code files: offers options via fzf to edit or save
################################################################################

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
DOWNLOADS_DIR="$HOME/storage/downloads"
ZOXIDE_BIN=$(command -v zoxide 2>/dev/null || echo "")

################################################################################
# Helper Functions
################################################################################

# Print colored output
print_info() {
    echo -e "${BLUE}ℹ${NC} $1"
}

print_success() {
    echo -e "${GREEN}✓${NC} $1"
}

print_error() {
    echo -e "${RED}✗${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}⚠${NC} $1"
}

# Check if a command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Ensure required tools are available
check_requirements() {
    local missing_tools=()
    
    if ! command_exists fzf; then
        missing_tools+=("fzf")
    fi
    
    if [[ -z "$ZOXIDE_BIN" ]]; then
        print_warning "zoxide not found - zoxide option will be unavailable"
    fi
    
    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        print_error "Missing required tools: ${missing_tools[*]}"
        print_info "Install with: pkg install ${missing_tools[*]}"
        exit 1
    fi
}

# Check if downloads directory exists
ensure_downloads_dir() {
    if [[ ! -d "$DOWNLOADS_DIR" ]]; then
        print_info "Creating downloads directory: $DOWNLOADS_DIR"
        mkdir -p "$DOWNLOADS_DIR"
    fi
}

# Get file extension
get_file_extension() {
    local filename="$1"
    echo "${filename##*.}" | tr '[:upper:]' '[:lower:]'
}

# Determine if file is a media/binary file
is_media_file() {
    local ext="$1"
    
    # Image extensions
    local image_exts="jpg|jpeg|png|gif|webp|bmp|svg|ico|tiff|heic|heif"
    
    # Video extensions
    local video_exts="mp4|mkv|avi|mov|flv|wmv|webm|m3u8|m4v|3gp|3g2"
    
    # Audio extensions
    local audio_exts="mp3|wav|flac|aac|ogg|m4a|wma|opus|aiff|alac"
    
    # Executable/Binary extensions
    local binary_exts="bin|exe|apk|so|o|pyc|class|jar|zip|tar|gz|rar|7z|bz2"
    
    if [[ $ext =~ ^($image_exts|$video_exts|$audio_exts|$binary_exts)$ ]]; then
        return 0
    fi
    return 1
}

# Copy file to downloads
copy_to_downloads() {
    local source_file="$1"
    local filename=$(basename "$source_file")
    local dest_path="$DOWNLOADS_DIR/$filename"
    
    # Handle file name conflicts
    local counter=1
    local base_name="${filename%.*}"
    local ext="${filename##*.}"
    
    while [[ -f "$dest_path" ]]; do
        dest_path="$DOWNLOADS_DIR/${base_name}_${counter}.${ext}"
        ((counter++))
    done
    
    cp "$source_file" "$dest_path"
    print_success "File saved to: $dest_path"
}

# Get zoxide directories and let user pick one
pick_zoxide_directory() {
    if [[ -z "$ZOXIDE_BIN" ]]; then
        print_error "zoxide is not installed" >&2
        return 1
    fi
    
    # Send info message to stderr so it doesn't interfere with stdout
    print_info "Available zoxide directories:" >&2
    
    local selected_dir
    selected_dir=$("$ZOXIDE_BIN" query -l | \
        fzf --preview 'ls -lah {}' \
            --preview-window right:40% \
            --header 'Select a zoxide directory' \
            --border \
            --margin 1 2>/dev/null)
    
    if [[ -z "$selected_dir" ]]; then
        print_warning "No directory selected" >&2
        return 1
    fi
    
    # Only output the directory path to stdout
    echo "$selected_dir"
}

# Save file to zoxide directory
save_to_zoxide() {
    local source_file="$1"
    local filename=$(basename "$source_file")
    
    local selected_dir
    selected_dir=$(pick_zoxide_directory)
    
    # Verify we got a valid directory
    if [[ -z "$selected_dir" || ! -d "$selected_dir" ]]; then
        print_warning "Cancelled saving to zoxide directory"
        return 1
    fi
    
    # Handle file name conflicts
    local dest_path="$selected_dir/$filename"
    local counter=1
    local base_name="${filename%.*}"
    local ext="${filename##*.}"
    
    while [[ -f "$dest_path" ]]; do
        dest_path="$selected_dir/${base_name}_${counter}.${ext}"
        ((counter++))
    done
    
    cp "$source_file" "$dest_path"
    print_success "File saved to: $dest_path"
}

# Open file with neovim
open_with_neovim() {
    local file="$1"
    
    if ! command_exists nvim; then
        print_error "neovim is not installed"
        print_info "Install with: pkg install neovim"
        return 1
    fi
    
    nvim "$file"
}

# Show fzf prompt with action options
show_action_menu() {
    local file="$1"
    
    local options=("open with neovim" "save to downloads" "save to zoxide")
    
    local selected
    selected=$(printf '%s\n' "${options[@]}" | \
        fzf --header "What would you like to do?" \
            --border \
            --margin 1 \
            --bind "ctrl-c:abort")
    
    case "$selected" in
        "open with neovim")
            open_with_neovim "$file"
            ;;
        "save to downloads")
            copy_to_downloads "$file"
            ;;
        "save to zoxide")
            save_to_zoxide "$file"
            ;;
        *)
            print_warning "No action selected"
            return 1
            ;;
    esac
}

################################################################################
# Main Logic
################################################################################

main() {
    # Validate arguments
    if [[ $# -eq 0 ]]; then
        print_error "No file specified"
        echo "Usage: $0 <file_path>"
        exit 1
    fi
    
    local file_path="$1"
    
    # Check if file exists
    if [[ ! -f "$file_path" ]]; then
        print_error "File not found: $file_path"
        exit 1
    fi
    
    # Check requirements
    check_requirements
    ensure_downloads_dir
    
    # Get file info
    local filename=$(basename "$file_path")
    local extension=$(get_file_extension "$filename")
    
    print_info "Processing file: $filename (.$extension)"
    
    # Handle media files
    if is_media_file "$extension"; then
        print_info "Detected media/binary file - automatically saving to downloads"
        copy_to_downloads "$file_path"
        exit 0
    fi
    
    # Handle text/code files
    print_info "Detected text/code file"
    show_action_menu "$file_path"
}

# Run main function
main "$@"
